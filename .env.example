# Copy to .env and adjust as needed.

# ---- RabbitMQ ----
RABBITMQ_URL=amqp://aether:aether@rabbitmq:5672/
RABBITMQ_EXCHANGE=aether.events
RABBITMQ_DLX=aether.dlx
RABBITMQ_PREFETCH=16

# ---- Postgres + pgvector ----
POSTGRES_DSN=postgres://aether:aether@postgres:5432/aether?sslmode=disable
POSTGRES_MAX_CONNS=20

# ---- Ollama (default LLM provider) ----
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.1:8b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---- BYO providers (used only when set; UI can override per-request) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest

# ---- LLM routing ----
# default | openai | anthropic | ollama | custom
AETHER_LLM_PROVIDER=ollama

# ---- Master key for encrypting UI-supplied keys at rest ----
# 32-byte base64 key. Generate with:
#   openssl rand -base64 32
AETHER_MASTER_KEY=replace_me_with_a_32_byte_base64_key

# ---- OpenTelemetry ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAMESPACE=aetherflow

# ---- Gateway ----
GATEWAY_HTTP_ADDR=:8080
GATEWAY_UI_PATH=/app/web/ui

# ---- DNS discovery ----
# When set, services resolve peers via SRV lookups under this base.
AETHER_DNS_BASE=aether.local
AETHER_DNS_RESOLVER=1.1.1.1:53
